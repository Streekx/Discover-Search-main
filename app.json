{
  "expo": {
    "name": "StreekX",
    "slug": "streekx",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "streekx",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F0F8FF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.streekx.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "StreekX needs microphone access for voice search.",
        "NSSpeechRecognitionUsageDescription": "StreekX needs speech recognition for voice search."
      }
    },
    "android": {
      "package": "com.streekx.app",
      "permissions": [
        "RECORD_AUDIO",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#A2D2FF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-av",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow StreekX to use the microphone for voice search.",
          "speechRecognitionPermission": "Allow StreekX to use speech recognition for voice search."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
